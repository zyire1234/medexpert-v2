# ===== Server =====
PORT=5000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API.
# Example for local dev with the static index.html opened via a dev server:
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500

# ===== MySQL Database =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=medexpert_user
DB_PASSWORD=change_this_password
DB_NAME=medexpert_db

# ===== JWT =====
JWT_SECRET=change_this_to_a_long_random_secret_value
JWT_EXPIRES_IN=7d
JWT_ADMIN_SECRET=change_this_to_a_different_long_random_secret_value
JWT_ADMIN_EXPIRES_IN=1d

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=10

# ===== Initial admin (used only by db/seed.js, change immediately after first login) =====
SEED_ADMIN_EMAIL=admin@medexpert.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin
